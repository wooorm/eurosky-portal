# Node
TZ=UTC
PORT=4075
HOST=0.0.0.0
NODE_ENV=production

# App
LOG_LEVEL=info
APP_URL=https://portal.eurosky.tech/
# Generate an APP_KEY with: node ace generate:key or openssl rand -hex 32
APP_KEY="${APP_KEY}"

DATABASE_AUTOMIGRATE=true
DATABASE_PATH=/data/production.sqlite3

ATPROTO_OAUTH_CLIENT_ID=https://portal.eurosky.tech/oauth-client-metadata.json
OAUTH_SERVICE=https://eurosky.social/

# Session
SESSION_DRIVER=cookie
