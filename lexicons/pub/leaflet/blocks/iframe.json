{
  "id": "pub.leaflet.blocks.iframe",
  "defs": {
    "main": {
      "type": "object",
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "height": {
          "type": "integer",
          "maximum": 1600,
          "minimum": 16
        },
        "aspectRatio": {
          "ref": "#aspectRatio",
          "type": "ref"
        }
      }
    },
    "aspectRatio": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}