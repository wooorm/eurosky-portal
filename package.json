{
  "name": "eurosky-portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "^24.13.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "db:migrate": "node ace migration:run",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json",
    "lex": "./node_modules/.bin/lex",
    "lex:build": "pnpm lex build --clear --indexFile --out ./app/lexicons"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#collections/*": "./app/collections/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#lexicons": "./app/lexicons/index.js",
    "#events/*": "./app/events/*.js",
    "#extensions/*": "./app/extensions/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#utils/*": "./app/utils/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "@types/proxy-addr": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/content": "^1.6.1",
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@atproto-labs/simple-store": "^0.3.0",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lex": "^0.0.24",
    "@atproto/lex-client": "^0.0.19",
    "@atproto/oauth-client-node": "^0.3.17",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@hono/node-server": "^1.13.8",
    "@inertiajs/core": "^2.3.21",
    "@inertiajs/react": "^2.3.21",
    "@tailwindcss/vite": "^4.2.2",
    "@thisismissem/adonisjs-atproto-oauth": "^3.0.3",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.3.1",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "edge-markdown": "^1.10.1",
    "edge.js": "^6.5.0",
    "hono": "^4.7.10",
    "luxon": "^3.7.2",
    "motion": "^12.38.0",
    "proxy-addr": "^2.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "simple-icons": "^16.16.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "lodash-es": ">=4.18.0"
    }
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
